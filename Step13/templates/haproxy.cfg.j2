global
    daemon
    maxconn 256
{% if haproxy_stats_socket %}
    stats socket {{ haproxy_stats_socket }}
{% endif %}

defaults
    mode http
    timeout connect 5000ms
    timeout client 50000ms
    timeout server 50000ms
listen cluster
    balance roundrobin
    bind {{ansible_eth1.ipv4.address}}:80
    mode http
    stats enable
    balance roundrobin
{% for backend in groups['web'] %}
    server {{hostvars[backend].inventory_hostname | upper}} {{hostvars[backend].ansible_eth1.ipv4.address}} check port 80 weight {{ hostvars[backend]['haproxy_backend_weight'] | default(100) }}
{% endfor %}
    option httpchk HEAD / HTTP/1.0
